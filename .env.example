# GLM（智谱）模型配置
# 仅填写示例，不要在仓库中提交真实密钥
GLM_API_KEY=
GLM_MODEL=glm-4.5-air
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_INCLUDE_THINKING=false

# QWEN（千问 / DashScope）模型配置
# 走 DashScope OpenAI 兼容接口：https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen3-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_INCLUDE_THINKING=false

# ReMe 记忆（Chroma 向量库 + JSONL 落盘）配置
QWEN_EMBEDDING_MODEL=qwen3-vl-embedding
QWEN_EMBEDDING_DIMS=1024
ANT_USER_ID=local_user

# AgentScope 项目信息（可选）
AGENTSCOPE_PROJECT=AntAgent
AGENTSCOPE_NAME=DesktopPet

# 结构化事件日志控制（可选）
LOG_THINKING=true
